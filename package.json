{
  "name": "ailouros-ui",
  "private": true,
  "version": "0.1.0",
  "description": "Vue 3 frontend for the AIlourOS multi-agent orchestration UI.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,vue,json,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,json,css,html}\"",
    "ci": "npm run lint && npm run type-check && npm run format:check && npm run build",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report ../var/artifacts/e2e/report",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:preview": "tauri dev --no-watch"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "dependencies": {
    "dompurify": "^3.2.2",
    "marked": "^15.0.4",
    "pinia": "^2.3.1",
    "sortablejs": "^1.15.6",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.59.1",
    "@types/sortablejs": "^1.15.8",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.0.5",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.2.0"
  }
}
