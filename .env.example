# Public web API base URL.
# Leave empty when the UI is served behind the same origin as the backend.
VITE_API_BASE_URL=

# Desktop/Tauri fallback backend port used by sync bootstrap helpers.
VITE_DESKTOP_BACKEND_PORT=8000

# Optional build output directory override.
# Example for embedded monorepo builds: ../backend/UI/Web
# VITE_BUILD_OUT_DIR=dist

# Optional Playwright target.
# When omitted, Playwright starts a local Vite dev server on port 5174.
# E2E_BASE_URL=http://127.0.0.1:5174
